<?xml version="1.0" encoding="UTF-8"?>
<display version="2.0.0">
  <name>Test Writable Widgets</name>
  <width>700</width>
  <height>620</height>

  <!-- Title -->
  <widget type="label" version="2.0.0">
    <name>Title</name>
    <x>10</x><y>10</y><width>680</width><height>30</height>
    <text>Writable Widget Enable/Disable Test</text>
    <font><font name="Default Bold" family="Liberation Sans" style="BOLD" size="16.0"/></font>
    <foreground_color><color name="Header" red="0" green="70" blue="127"/></foreground_color>
  </widget>

  <widget type="label" version="2.0.0">
    <name>Hint</name>
    <x>10</x><y>42</y><width>680</width><height>20</height>
    <text>Use "Enable Acnet Setting" button to enable/disable all widgets below.</text>
    <foreground_color><color name="OK" red="0" green="128" blue="0"/></foreground_color>
  </widget>

  <!-- Column headers -->
  <widget type="label" version="2.0.0">
    <name>ColWidget</name>
    <x>10</x><y>70</y><width>160</width><height>20</height>
    <text>Widget</text>
    <font><font name="Default Bold" family="Liberation Sans" style="BOLD" size="11.0"/></font>
  </widget>
  <widget type="label" version="2.0.0">
    <name>ColPV</name>
    <x>175</x><y>70</y><width>200</width><height>20</height>
    <text>PV (local, writable)</text>
    <font><font name="Default Bold" family="Liberation Sans" style="BOLD" size="11.0"/></font>
  </widget>
  <widget type="label" version="2.0.0">
    <name>ColWidget2</name>
    <x>390</x><y>70</y><width>160</width><height>20</height>
    <text>Widget</text>
    <font><font name="Default Bold" family="Liberation Sans" style="BOLD" size="11.0"/></font>
  </widget>
  <widget type="label" version="2.0.0">
    <name>ColPV2</name>
    <x>560</x><y>70</y><width>130</width><height>20</height>
    <text>PV (local, writable)</text>
    <font><font name="Default Bold" family="Liberation Sans" style="BOLD" size="11.0"/></font>
  </widget>

  <!-- ROW 1 - Text Entry / Spinner -->
  <widget type="label" version="2.0.0">
    <name>L1</name>
    <x>10</x><y>100</y><width>160</width><height>30</height>
    <text>Text Entry</text>
  </widget>
  <widget type="textentry" version="3.0.0">
    <name>TextEntry</name>
    <x>175</x><y>100</y><width>180</width><height>30</height>
    <pv_name>loc://testNum(50.0)</pv_name>
  </widget>

  <widget type="label" version="2.0.0">
    <name>L1b</name>
    <x>390</x><y>100</y><width>160</width><height>30</height>
    <text>Spinner</text>
  </widget>
  <widget type="spinner" version="2.0.0">
    <name>Spinner</name>
    <x>560</x><y>100</y><width>120</width><height>30</height>
    <pv_name>loc://testNum(50.0)</pv_name>
  </widget>

  <!-- ROW 2 - Bool Button / Slide Button -->
  <widget type="label" version="2.0.0">
    <name>L2</name>
    <x>10</x><y>150</y><width>160</width><height>30</height>
    <text>Bool Button</text>
  </widget>
  <widget type="bool_button" version="2.0.0">
    <name>BoolButton</name>
    <x>175</x><y>150</y><width>120</width><height>30</height>
    <pv_name>loc://testBool(0)</pv_name>
    <on_label>ON</on_label>
    <off_label>OFF</off_label>
  </widget>

  <widget type="label" version="2.0.0">
    <name>L2b</name>
    <x>390</x><y>150</y><width>160</width><height>30</height>
    <text>Slide Button</text>
  </widget>
  <widget type="slide_button" version="2.0.0">
    <name>SlideButton</name>
    <x>560</x><y>150</y><width>120</width><height>30</height>
    <pv_name>loc://testBool(0)</pv_name>
  </widget>

  <!-- ROW 3 - Check Box / Scaled Slider -->
  <widget type="label" version="2.0.0">
    <name>L3</name>
    <x>10</x><y>200</y><width>160</width><height>30</height>
    <text>Check Box</text>
  </widget>
  <widget type="checkbox" version="2.0.0">
    <name>CheckBox</name>
    <x>175</x><y>200</y><width>180</width><height>30</height>
    <pv_name>loc://testBool(0)</pv_name>
    <label>Check to write 1</label>
  </widget>

  <widget type="label" version="2.0.0">
    <name>L3b</name>
    <x>390</x><y>200</y><width>160</width><height>30</height>
    <text>Scaled Slider</text>
  </widget>
  <widget type="scaledslider" version="2.0.0">
    <name>ScaledSlider</name>
    <x>560</x><y>195</y><width>120</width><height>40</height>
    <pv_name>loc://testNum(50.0)</pv_name>
    <minimum>0.0</minimum>
    <maximum>100.0</maximum>
    <scale_font><font name="Default" family="Liberation Sans" style="REGULAR" size="8.0"/></scale_font>
  </widget>

  <!-- ROW 4 - Choice Button / Scroll Bar -->
  <widget type="label" version="2.0.0">
    <name>L4</name>
    <x>10</x><y>255</y><width>160</width><height>30</height>
    <text>Choice Button</text>
  </widget>
  <widget type="choice" version="2.0.0">
    <name>ChoiceButton</name>
    <x>175</x><y>255</y><width>180</width><height>30</height>
    <pv_name>loc://testEnum&lt;VEnum&gt;(0, &quot;A&quot;, &quot;B&quot;, &quot;C&quot;)</pv_name>
  </widget>

  <widget type="label" version="2.0.0">
    <name>L4b</name>
    <x>390</x><y>255</y><width>160</width><height>30</height>
    <text>Scroll Bar</text>
  </widget>
  <widget type="scrollbar" version="2.0.0">
    <name>ScrollBar</name>
    <x>560</x><y>255</y><width>120</width><height>30</height>
    <pv_name>loc://testNum(50.0)</pv_name>
    <minimum>0.0</minimum>
    <maximum>100.0</maximum>
    <limits_from_pv>false</limits_from_pv>
    <bar_length>10.0</bar_length>
    <increment>1.0</increment>
    <horizontal>true</horizontal>
    <show_value_tip>true</show_value_tip>
  </widget>

  <!-- ROW 5 - Combo Box -->
  <widget type="label" version="2.0.0">
    <name>L5</name>
    <x>10</x><y>305</y><width>160</width><height>30</height>
    <text>Combo Box</text>
  </widget>
  <widget type="combo" version="2.0.0">
    <name>Combo</name>
    <x>175</x><y>305</y><width>180</width><height>30</height>
    <pv_name>loc://testEnum&lt;VEnum&gt;(0, &quot;A&quot;, &quot;B&quot;, &quot;C&quot;)</pv_name>
  </widget>

  <!-- ROW 6 - Radio Button -->
  <widget type="label" version="2.0.0">
    <name>L6</name>
    <x>10</x><y>355</y><width>160</width><height>30</height>
    <text>Radio Button</text>
  </widget>
  <widget type="radio" version="2.0.0">
    <name>Radio</name>
    <x>175</x><y>355</y><width>180</width><height>30</height>
    <pv_name>loc://testEnum&lt;VEnum&gt;(0, &quot;A&quot;, &quot;B&quot;, &quot;C&quot;)</pv_name>
  </widget>

  <!-- Separator -->
  <widget type="label" version="2.0.0">
    <name>SepLine</name>
    <x>10</x><y>420</y><width>680</width><height>2</height>
    <background_color><color name="Mid" red="148" green="148" blue="148"/></background_color>
    <border_alarm_sensitive>false</border_alarm_sensitive>
  </widget>

  <!-- Readback row -->
  <widget type="label" version="2.0.0">
    <name>StatusLabel</name>
    <x>10</x><y>430</y><width>200</width><height>25</height>
    <text>Numeric readback (loc://testNum):</text>
  </widget>
  <widget type="textupdate" version="2.0.0">
    <name>Readback</name>
    <x>215</x><y>430</y><width>120</width><height>25</height>
    <pv_name>loc://testNum(50.0)</pv_name>
  </widget>

  <widget type="label" version="2.0.0">
    <name>EnumLabel</name>
    <x>10</x><y>465</y><width>200</width><height>25</height>
    <text>Enum readback (loc://testEnum):</text>
  </widget>
  <widget type="textupdate" version="2.0.0">
    <name>EnumReadback</name>
    <x>215</x><y>465</y><width>120</width><height>25</height>
    <pv_name>loc://testEnum&lt;VEnum&gt;(0, &quot;A&quot;, &quot;B&quot;, &quot;C&quot;)</pv_name>
  </widget>

  <!-- Instructions -->
  <widget type="label" version="2.0.0">
    <name>Instructions</name>
    <x>10</x><y>510</y><width>680</width><height>100</height>
    <text>HOW TO TEST:
1. On startup all widgets should be DISABLED (greyed out / not interactive).
2. Click "Enable Acnet Setting" in the toolbar, pick a duration.
3. All widgets above should become ENABLED immediately.
4. Wait for the timer to expire (or click the button again to disable early).
5. All widgets should become DISABLED again automatically.</text>
    <foreground_color><color name="Blue" red="0" green="0" blue="200"/></foreground_color>
    <border_style>1</border_style>
  </widget>

</display>